<div class="cc-widget-actor-dropper inventory-table inventory" id="widget-{{id}}">

    <div class="add-actor-header">
        <input type="text" class="ad-title-input" value="{{title}}" placeholder="{{ccLocalize 'ui.widgetTitle'}}">
        <div class="ad-header-actions">
            {{#if showEncounterTools}}
            <span class="ad-total-xp">{{ccLocalize "ui.xpLabel"}}: {{encounterXp}}</span>
            {{#if showPf2ePartyMeta}}
            <span class="ad-party-meta">{{ccLocalize "dialog.partyLevel"}} {{pf2ePartyLevel}} <i class="fas fa-user"></i>{{pf2ePartySize}}</span>
            {{/if}}
            {{/if}}
            {{#if actors}}
            {{#if showEncounterTools}}
            <button class="ad-balance-btn" title="{{ccLocalize 'ui.balanceEncounter'}}">
                <i class="fas fa-scale-balanced"></i>
            </button>
            {{/if}}
            <button class="ad-drop-map-btn" title="{{ccLocalize 'dialog.dropActorsToMap'}}">
                <i class="fas fa-street-view"></i>
            </button>
            {{/if}}
        </div>
    </div>
    {{#if actors}}
    {{#each actors}}
    <div class="inventory-item" data-uuid="{{uuid}}" {{#if ../isGM}}data-drag="true" draggable="true" {{/if}}
            data-entry-id="{{id}}" data-entry-uuid="{{uuid}}"
            data-title="{{name}}">
        <div class="item-image">
            <img src="{{img}}" alt="{{name}}">
        </div>

        <div class="item-details">
            <div class="item-name">{{name}}</div>
            {{#if ../showCrColumn}}
            {{#if cr}}
            <div class="item-weight" style="font-size: 11px; color: var(--cc-text-muted);">{{ccLocalize "ui.cr"}} {{cr}}
            </div>
            {{/if}}
            {{/if}}
        </div>

        <div class="quantity-control" style="text-align:center">
            <input type="number" class="quantity-input ad-quantity-input" data-uuid="{{uuid}}" value="{{quantity}}"
                min="1" style="width: 40px; text-align: center;">
        </div>

        <div class="item-actions" style="text-align:center">
            <i class="fas fa-street-view inventory-button actor-drop-individual" data-uuid="{{uuid}}"
                title="{{ccLocalize 'ui.drop'}}"></i>
            <i class="fas fa-trash inventory-button ad-remove-btn" data-uuid="{{uuid}}"
                title="{{ccLocalize 'ui.remove'}}"></i>
        </div>
    </div>
    {{/each}}
    {{else}}
    <div class="cc-ad-drop-area large">
        <i class="fas fa-user-plus"></i>
        <span>{{ccLocalize "ui.dropActorsHere"}}</span>
    </div>
    {{/if}}
</div>
