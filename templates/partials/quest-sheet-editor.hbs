
<div class="content-header">
  <h2><i class="fas fa-info-circle"></i> {{#if labelOverride}}{{labelOverride}}{{else}}{{ccLocalize "names.quest"
    }}{{/if}}</h2>
  {{#if isGM}}
  <div class="header-actions">
    <i class="fas fa-wrench widget-tray-toggle" data-action="toggleInfoWidgetTray"></i>
  </div>
  {{/if}}
</div>
{{#if actor}}
<div class="form-section">
  {{{actor}}}
</div>
{{/if}}
{{#if isGM}}
<div class="widget-tray info {{#unless isWidgetTrayOpen}}collapsed{{/unless}}">
  <div class="tray-inner">
    <div class="tray-section">
      <div class="active-widgets-bar">
        {{#if activewidget.length}}
        {{#each activewidget}}
        {{#if @first}}<div class="widget-drop-slot" data-widget-tab="info" data-widget-insert-pos="0"></div>{{/if}}
        <div class="widget-tag active" data-widget-id="{{this.id}}" data-widget-tab="info">
          <span class="name">{{this.widgetName}} {{counter}}</span>
          <i class="fas fa-circle-x action-icon" data-action="deactivateWidget" data-id="{{this.id}}"
            title="{{localize 'button.deactivate'}}"></i>
        </div>
        <div class="widget-drop-slot" data-widget-tab="info" data-widget-after-index="{{@index}}"></div>
        {{/each}}
        {{/if}}
        {{#if inactivewidgets.length}}
        {{#each inactivewidgets}}
        <div class="tray-card inactive">
          <span class="name" data-action="activateWidget" data-id="{{this.id}}">{{widgetName}} {{counter}}</span>
          <div class="tray-actions">
            <i class="fas fa-exchange-alt action-icon" data-action="swapWidgetTab" data-id="{{this.id}}"
              title="Move to Widgets Tab"></i>
            <i class="fas fa-trash action-icon delete" data-action="deleteWidget" data-id="{{this.id}}"
              data-type="{{this.widgetName}}"></i>
          </div>
        </div>
        {{/each}}
        {{/if}}
      </div>
    </div>
  </div>
  {{!-- Section: Available Widgets --}}
  <div class="tray-section">
    <h3>{{ccLocalize "widgets.available"}}</h3>
    <div class="tray-grid">
      {{#each availableWidgets}}
      <div class="tray-card available">
        <span class="name" data-action="addWidget" data-name="{{this.name}}">{{this.name}}</span>
      </div>
      {{/each}}
    </div>
  </div>
  <i class="fas {{#if widgetsPosition}}fa-arrow-up-to-line{{else}}fa-arrow-down-to-line{{/if}} move-widget-tag"
    data-action="toggleWidgetPosition" title="{{ccLocalize 'ui.moveWidgets'}}"></i>
</div>
{{/if}}

{{#if widgetsToRender}}
{{#unless widgetsPosition}}
<article class="cc-widgets-render">
  {{{this.widgetsToRender}}}
</article>
{{/unless}}
{{/if}}

<section class="cc-quest-sheet-editor" data-doc-uuid="{{doc.uuid}}">

    {{{richTextDescription}}}

  <div class="cc-quest-card-section cc-quest-links-main">
    <h4>Quest Links</h4>
    <div class="cc-quest-link-grid">
      {{#if (or isGM quest.questGiver)}}
        <div class="cc-quest-link-block {{#if isGM}}cc-quest-link-dropzone" data-link-role="giver" data-doc-uuid="{{doc.uuid}}" data-quest-id="{{quest.id}}{{/if}}">
          <strong>Quest Giver</strong>
          <div class="cc-quest-link-list">
            {{#if quest.questGiver}}
              <div class="cc-quest-link-pill">
                <span data-action="openJournal" data-uuid="{{quest.questGiver.uuid}}">{{quest.questGiver.name}}</span>
                {{#if isGM}}<i class="fas fa-times-circle" data-action="clearQuestGiver" data-quest-id="{{quest.id}}"></i>{{/if}}
              </div>
            {{/if}}
          </div>
          {{#if isGM}}{{#unless quest.questGiver}}<div class="cc-quest-link-dropzone-text" data-link-role="giver" data-doc-uuid="{{doc.uuid}}" data-quest-id="{{quest.id}}">{{ccLocalize "quest.dropQuestGiver"}}</div>{{/unless}}{{/if}}
        </div>
      {{/if}}

      {{#if (or isGM quest.relatedDocs.length)}}
        <div class="cc-quest-link-block {{#if isGM}}cc-quest-link-dropzone" data-link-role="related" data-doc-uuid="{{doc.uuid}}" data-quest-id="{{quest.id}}{{/if}}">
          <strong>Related Sheets</strong>
          <div class="cc-quest-link-list">
            {{#each quest.relatedDocs}}
              <div class="cc-quest-link-pill">
                <span data-action="openJournal" data-uuid="{{this.uuid}}">{{this.name}}</span>
                {{#if ../isGM}}<i class="fas fa-times-circle" data-action="removeQuestLink" data-quest-id="{{../quest.id}}" data-field="relatedUuids" data-value="{{this.uuid}}"></i>{{/if}}
              </div>
            {{/each}}
          </div>
          {{#if isGM}}{{#unless quest.relatedDocs}}<div class="cc-quest-link-dropzone-text">{{ccLocalize "quest.dropRelated"}}</div>{{/unless}}{{/if}}
        </div>
      {{/if}}

      {{#if isGM}}


        <div class="cc-quest-link-block cc-quest-link-dropzone" data-link-role="dependency" data-doc-uuid="{{doc.uuid}}" data-quest-id="{{quest.id}}">
          <strong>Depends On</strong>
          <div class="cc-quest-link-list">
            {{#each quest.dependencyItems}}
              <div class="cc-quest-link-pill {{this.statusClass}}">
                <span data-action="openJournal" data-uuid="{{this.uuid}}">{{this.title}}</span>
                <i class="fas fa-times-circle" data-action="removeQuestLink" data-quest-id="{{../quest.id}}" data-field="dependencies" data-value="{{this.key}}"></i>
              </div>
            {{/each}}
          </div>
          {{#unless quest.dependencyItems}}<div class="cc-quest-link-dropzone-text">{{ccLocalize "quest.dropDependency"}}</div>{{/unless}}
        </div>

        <div class="cc-quest-link-block cc-quest-link-dropzone" data-link-role="unlock" data-doc-uuid="{{doc.uuid}}" data-quest-id="{{quest.id}}">
          <strong>Unlocks</strong>
          <div class="cc-quest-link-list">
            {{#each quest.unlockItems}}
              <div class="cc-quest-link-pill {{this.statusClass}}">
                <span data-action="openJournal" data-uuid="{{this.uuid}}">{{this.title}}</span>
                <i class="fas fa-times-circle" data-action="removeQuestLink" data-quest-id="{{../quest.id}}" data-field="unlocks" data-value="{{this.key}}"></i>
              </div>
            {{/each}}
          </div>
          {{#unless quest.unlockItems}}<div class="cc-quest-link-dropzone-text">{{ccLocalize "quest.dropUnlock"}}</div>{{/unless}}
        </div>
        <div class="cc-quest-link-block cc-quest-link-dropzone" data-link-role="macro" data-doc-uuid="{{doc.uuid}}" data-quest-id="{{quest.id}}">
          <strong>{{ccLocalize "quest.macros"}}</strong>
          <div class="cc-quest-link-list">
            {{#each quest.macroItems}}
              <div class="cc-quest-link-pill">
                <span data-action="executeQuestMacro" data-macro-uuid="{{this.uuid}}"><i class="fas fa-play"></i> {{this.name}}</span>
                <i class="fas fa-times-circle" data-action="removeQuestLink" data-quest-id="{{../quest.id}}" data-field="linkedMacros" data-value="{{this.uuid}}"></i>
              </div>
            {{/each}}
          </div>
          {{#unless quest.macroItems}}<div class="cc-quest-link-dropzone-text">{{ccLocalize "quest.dropMacro"}}</div>{{/unless}}
        </div>
        
      {{/if}}
    </div>
  </div>

  {{#if (or isGM quest.hasVisibleObjectives)}}
    <div class="objectives-section">
      <div class="objectives-header">
        <strong>{{ccLocalize "quest.objectives"}}</strong>
        {{#if isGM}}
          <a class="add-objective" data-quest-id="{{quest.id}}" data-doc-uuid="{{doc.uuid}}" title="{{ccLocalize 'quest.addObjective'}}"><i class="fas fa-circle-plus"></i></a>
        {{/if}}
      </div>
      <ul class="objective-list">
        {{> "modules/campaign-codex/templates/partials/quest-objective.hbs" objectives=quest.objectives uuid=doc.uuid quest=quest isGM=isGM isGroupSheet=false questDocUuid=doc.uuid}}
      </ul>
    </div>
  {{/if}}
</section>

{{#if widgetsToRender}}
{{#if widgetsPosition}}
<article class="cc-widgets-render">
  {{{this.widgetsToRender}}}
</article>
{{/if}}
{{/if}}
