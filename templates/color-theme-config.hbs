<div class="form-body scrollable">
    <input type="file" id="wgtgm-import-file" accept=".json" style="display:none;" />

    <p class="notes">{{ccLocalize "ui.themeConfigDescription"}}</p>

    {{#each fieldsets as |fieldset|}}
    <fieldset>
        <legend>{{fieldset.legend}}</legend>
        {{#each fieldset.fields as |f|}}
        {{formField f.field value=f.value}}
        {{/each}}
    </fieldset>
    {{/each}}
</div>